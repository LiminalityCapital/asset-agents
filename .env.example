# Azure OpenAI (shared with azure-search-rag backend — same values)
ENDPOINT_URL=https://liminality-ai.openai.azure.com/
AZURE_OPENAI_API_KEY=
DEPLOYMENT_NAME=liminality-gpt5
API_VERSION=2025-03-01-preview

# Azure AI Search (shared with azure-search-rag backend — same values)
SEARCH_ENDPOINT=https://liminality-ai-search-east.search.windows.net
SEARCH_KEY=
SEARCH_INDEX_NAME=liminality-chunk-index

# Retrieval tuning (optional — defaults shown)
RETRIEVAL_MODE=hybrid
RETRIEVAL_DEFAULT_TOP_K=20

# Teams delivery (Power Automate "Send webhook alerts to a chat/channel" workflow URL)
# Leave empty to skip posting; the alert still prints locally.
TEAMS_WEBHOOK_URL=

# Bagel base URL (both API calls and click-through links).
# If set, alerts render an "Explore in Bagel" button. If BAGEL_USER_ID is also set,
# the agent pre-creates a chat session seeded with a follow-up question so the user
# lands in a chat that already has a Q and an answer.
BAGEL_CHAT_URL=

# Bagel user_id the agent impersonates when creating sessions. Must match the
# `lc_uid` cookie value of the human who will click the link (otherwise the session
# will 404 for them). Get it from dev tools → Application → Cookies → lc_uid.
BAGEL_USER_ID=

USE_MOCK=1

# Postgres connection for the daily price hook (core.price_check).
# Expected schema: fx_spot_rates(business_date DATE, currency_pair TEXT, spot_rate NUMERIC).
# If unset, price_check falls back to the in-repo mock series for local dev.
DATABASE_URL=
